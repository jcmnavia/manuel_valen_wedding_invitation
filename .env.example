# ── Supabase (message wall / muro de mensajes) ──────────────────────────────
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings → API). BOTH are server-only — do NOT add a
# NEXT_PUBLIC_ prefix; the service-role key must never reach the browser.
#
# Also add these two in the Vercel dashboard (Project → Settings → Environment
# Variables) for Production and Preview so the deployed site can read/write.

# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# service_role secret (NOT the anon key). Bypasses RLS; keep it private.
SUPABASE_SERVICE_ROLE_KEY=
